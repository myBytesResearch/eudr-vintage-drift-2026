# Local environment for the EUDR pipeline notebooks and build script.
#
# Copy this file to `.env` (which is gitignored) and fill in the value
# below. Both `notebooks/02_live_gee_pipeline.ipynb` and
# `scripts/build_snapshot_2026_06_08.py` read EE_PROJECT from the
# environment. If python-dotenv is installed they also auto-load this
# file at start-up; otherwise export the variable manually before
# launching Jupyter, e.g.:
#
#   export $(grep -v "^#" .env | xargs)
#   jupyter notebook
#
# ---------------------------------------------------------------------
# EE_PROJECT
# ---------------------------------------------------------------------
# Your registered Google Earth Engine Cloud project ID.
#
# Where to get one:
#   1. Sign up for Earth Engine: https://earthengine.google.com/
#   2. Create a Google Cloud project and enable the Earth Engine API:
#      https://developers.google.com/earth-engine/cloud/projects
#   3. Register that Cloud project for Earth Engine use:
#      https://code.earthengine.google.com/register
#   4. Authenticate once on this machine:
#        earthengine authenticate
#
# Replace the placeholder with the project ID (NOT the project NUMBER).
EE_PROJECT=your-registered-cloud-project-id
